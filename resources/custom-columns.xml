</Item>
<Item Index="3">
<Value>Low – Address at Convenience</Value>
</Item>
<Item Index="4">
<Value>For Information Only</Value>
</Item>
</Items>
<AllowCustom>False</AllowCustom>
</BSIColumnItem>
<!--  Action Required  -->
<BSIColumnItem Index="4" Subtype="Text">
<n>Action Required</n>
<DisplayOrder>4</DisplayOrder>
<Deleted>False</Deleted>
<Format>Normal</Format>
<Precision>2</Precision>
<Multiline>True</Multiline>
</BSIColumnItem>
<!--  Due Date  -->
<BSIColumnItem Index="5" Subtype="Date">
<n>Due Date</n>
<DisplayOrder>5</DisplayOrder>
<Deleted>False</Deleted>
