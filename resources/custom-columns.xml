<!-- 
  Bluebeam Studio PoC — Custom Columns Definition
  Schema: BluebeamUserDefinedColumns (direct Revu export format).
  This is the only schema accepted by the importcustomcolumns API job.
  Generated from a real Revu export and extended with project review columns.
 -->
<BluebeamUserDefinedColumns>
<!--  Review Stage  -->
<BSIColumnItem Index="0" Subtype="Choice">
<n>Review Stage</n>
<DisplayOrder>0</DisplayOrder>
<Deleted>False</Deleted>
<Format>Normal</Format>
<Precision>2</Precision>
<Items>
<Item Index="0">
<Value>Step 1 – Out for Review</Value>
</Item>
<Item Index="1">
<Value>Step 2 – Reviewer Comments Received</Value>
</Item>
<Item Index="2">
<Value>Step 3 – Comments Under Coordination</Value>
</Item>
<Item Index="3">
<Value>Step 4 – Responses Issued to Reviewer</Value>
</Item>
<Item Index="4">
<Value>Step 5 – Final Review in Progress</Value>
</Item>
<Item Index="5">
<Value>Step 6 – Approved for Construction</Value>
</Item>
<Item Index="6">
<Value>Step 7 – Approved with Comments</Value>
</Item>
<Item Index="7">
<Value>Step 8 – Revise and Resubmit</Value>
</Item>
<Item Index="8">
<Value>Void – Superseded by Revision</Value>
</Item>
<Item Index="9">
<Value>On Hold – Pending Information</Value>
</Item>
</Items>
<AllowCustom>False</AllowCustom>
</BSIColumnItem>
<!--  Discipline  -->
<BSIColumnItem Index="1" Subtype="Choice">
<n>Discipline</n>
<DisplayOrder>1</DisplayOrder>
<Deleted>False</Deleted>
<Format>Normal</Format>
<Precision>2</Precision>
<Items>
<Item Index="0">
<Value>Architectural</Value>
</Item>
<Item Index="1">
<Value>Structural</Value>
</Item>
<Item Index="2">
<Value>Mechanical</Value>
</Item>
<Item Index="3">
<Value>Electrical</Value>
</Item>
<Item Index="4">
<Value>Plumbing</Value>
</Item>
<Item Index="5">
<Value>Civil</Value>
</Item>
<Item Index="6">
<Value>Fire Protection</Value>
</Item>
<Item Index="7">
<Value>Geotechnical</Value>
</Item>
<Item Index="8">
<Value>Landscape</Value>
</Item>
<Item Index="9">
<Value>Interior Design</Value>
</Item>
<Item Index="10">
<Value>Technology / AV / Security</Value>
</Item>
<Item Index="11">
<Value>General / Multi-Discipline</Value>
</Item>
</Items>
<AllowCustom>True</AllowCustom>
</BSIColumnItem>
<!--  Responsibility  -->
<BSIColumnItem Index="2" Subtype="Choice">
<n>Responsibility</n>
<DisplayOrder>2</DisplayOrder>
<Deleted>False</Deleted>
<Format>Normal</Format>
<Precision>2</Precision>
<Items>
<Item Index="0">
<Value>Owner</Value>
</Item>
<Item Index="1">
<Value>GC</Value>
</Item>
<Item Index="2">
<Value>Contractor</Value>
</Item>
<Item Index="3">
<Value>Architect</Value>
</Item>
<Item Index="4">
<Value>Engineer</Value>
</Item>
<Item Index="5">
<Value>Project Manager</Value>
</Item>
<Item Index="6">
<Value>Coordinator</Value>
</Item>
<Item Index="7">
<Value>Consultant</Value>
</Item>
<Item Index="8">
<Value>Authority Having Jurisdiction</Value>
</Item>
</Items>
<AllowCustom>False</AllowCustom>
</BSIColumnItem>
<!--  Priority  -->
<BSIColumnItem Index="3" Subtype="Choice">
<n>Priority</n>
<DisplayOrder>3</DisplayOrder>
<Deleted>False</Deleted>
<Format>Normal</Format>
<Precision>2</Precision>
<Items>
<Item Index="0">
<Value>Critical – Blocks Construction</Value>
</Item>
<Item Index="1">
<Value>High – Resolve Before Next Submittal</Value>
</Item>
<Item Index="2">
